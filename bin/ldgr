#!/bin/sh
set -eu
SCRIPT=$0
while [ -L "$SCRIPT" ]; do
  DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT")" && pwd)
  TARGET=$(readlink "$SCRIPT")
  case "$TARGET" in
    /*) SCRIPT=$TARGET ;;
    *) SCRIPT=$DIR/$TARGET ;;
  esac
done
DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT")" && pwd)
NATIVE="$DIR/native/ldgr"
if [ -x "$NATIVE" ]; then
  exec "$NATIVE" "$@"
fi
cd "$DIR/.."
if [ -f go.mod ] && [ -f main.go ]; then
  exec go run . "$@"
fi
echo "ldgr binary was not installed." >&2
echo "Reinstall with: npm install -g @hgwk/ldgr@latest" >&2
exit 1
